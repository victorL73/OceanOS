# ─────────────────────────────────────────────
#  MobyWorkspace Backend — Configuration
#  À copier en .env.local pour personnalisation
# ─────────────────────────────────────────────

# ── Serveur ─────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── Frontend (CORS) ─────────────────────────────────────────
# URL du frontend en production (ex: https://app.mobyworkspace.fr)
FRONTEND_URL=http://localhost:5173

# ── JWT ──────────────────────────────────────────────────────
# IMPORTANT: Changer cette valeur en production !
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_STRING

# OceanOS centralise les comptes et les donnees Mobywork.
MOBYWORK_AUTH_DRIVER=oceanos
MOBYWORK_DB_DRIVER=oceanos
MOBYWORK_DB_HOST=127.0.0.1
MOBYWORK_DB_PORT=3306
MOBYWORK_DB_NAME=OceanOS
MOBYWORK_DB_USER=root
MOBYWORK_DB_PASS=
MOBYWORK_SHARED_AUTH_URL=http://127.0.0.1/Mobywork/api/shared-auth.php
MOBYWORK_SQL_URL=http://127.0.0.1/Mobywork/api/sql.php
# Optionnel: sinon backend/.mobywork_bridge_secret est genere automatiquement.
# MOBYWORK_BRIDGE_TOKEN=CHANGE_ME_SHARED_SECRET

# ── IMAP (OVH ou autre) ─────────────────────────────────────
# Ces valeurs sont stockées par utilisateur dans la DB,
# mais peuvent aussi être globales ici en mode single-tenant
# IMAP_HOST=ssl0.ovh.net
# IMAP_PORT=993
# IMAP_USER=contact@votreboite.fr
# IMAP_PASSWORD=votre_mot_de_passe

# ── PrestaShop ───────────────────────────────────────────────
# PRESTASHOP_API_URL=https://www.votre-boutique.fr
# PRESTASHOP_API_KEY=VOTRE_CLE_API_PRESTASHOP

# ── IA (OpenRouter) ──────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
